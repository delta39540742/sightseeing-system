generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model app_user {
  user_id                                                   String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firebase_uid                                              String                  @unique
  email                                                     String
  display_name                                              String?
  avatar_url                                                String?
  created_at                                                DateTime                @default(now()) @db.Timestamptz(6)
  last_login_at                                             DateTime?               @db.Timestamptz(6)
  interaction_log                                           interaction_log[]
  landmark_recognition                                      landmark_recognition[]
  trip                                                      trip[]
  user_arm_stat                                             user_arm_stat[]
  user_objective_weights                                    user_objective_weights?
  user_preference                                           user_preference?
  user_similarity_user_similarity_similar_user_idToapp_user user_similarity[]       @relation("user_similarity_similar_user_idToapp_user")
  user_similarity_user_similarity_user_idToapp_user         user_similarity[]       @relation("user_similarity_user_idToapp_user")

  @@index([firebase_uid], map: "idx_user_firebase")
}

model bandit_arm {
  arm_id                 Int                      @id
  name                   String
  w_interest             Float
  w_pace                 Float
  w_distance             Float
  w_budget               Float
  w_weather              Float
  w_risk                 Float
  trip                   trip[]
  user_arm_stat          user_arm_stat[]
  user_objective_weights user_objective_weights[]
}

model event_log {
  log_id         BigInt   @id @default(autoincrement())
  event_name     String
  payload        Json
  published_at   DateTime @default(now()) @db.Timestamptz(6)
  consumer_count Int      @default(0)
  correlation_id String?  @db.Uuid

  @@index([correlation_id], map: "idx_log_corr", where: raw("(correlation_id IS NOT NULL)"))
  @@index([event_name, published_at(sort: Desc)], map: "idx_log_event")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model festival {
  festival_id          BigInt                    @id @default(autoincrement())
  name                 String
  description          String?
  city                 String
  start_date           DateTime                  @db.Date
  end_date             DateTime                  @db.Date
  affected_geom        Unsupported("geography")?
  traffic_impact_level Float?

  @@index([start_date, end_date], map: "idx_festival_dates")
  @@index([affected_geom], map: "idx_festival_geom", type: Gist)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model interaction_log {
  interaction_id   BigInt   @id @default(autoincrement())
  user_id          String   @db.Uuid
  place_id         BigInt?
  trip_id          String?  @db.Uuid
  interaction_type String
  rating           Float?
  context          Json?
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  place            place?   @relation(fields: [place_id], references: [place_id], onDelete: NoAction, onUpdate: NoAction)
  app_user         app_user @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([place_id], map: "idx_interaction_place")
  @@index([interaction_type], map: "idx_interaction_type")
  @@index([user_id, created_at(sort: Desc)], map: "idx_interaction_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model landmark_recognition {
  recognition_id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                     String   @db.Uuid
  trip_id                     String?  @db.Uuid
  image_url                   String
  predicted_landmark_class_id Int?
  predicted_place_id          BigInt?
  confidence                  Float
  is_mock                     Boolean  @default(true)
  created_at                  DateTime @default(now()) @db.Timestamptz(6)
  place                       place?   @relation(fields: [predicted_place_id], references: [place_id], onDelete: NoAction, onUpdate: NoAction)
  trip                        trip?    @relation(fields: [trip_id], references: [trip_id], onUpdate: NoAction)
  app_user                    app_user @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, created_at(sort: Desc)], map: "idx_recognition_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains an index with non-default null sort order and requires additional setup for migrations. Visit https://pris.ly/d/default-index-null-ordering for more info.
model place {
  place_id                                                          BigInt                   @id @default(autoincrement())
  name                                                              String
  description                                                       String?
  geom                                                              Unsupported("geography")
  lat                                                               Float?                   @default(dbgenerated("st_y((geom)::geometry)"))
  lng                                                               Float?                   @default(dbgenerated("st_x((geom)::geometry)"))
  min_price                                                         Int?
  max_price                                                         Int?
  price_type                                                        String
  avg_visit_duration_min                                            Int
  parking_available                                                 Boolean                  @default(false)
  wheelchair_access                                                 Boolean                  @default(false)
  public_transport                                                  Boolean                  @default(false)
  terrain_easiness                                                  Float?
  road_access_score                                                 Float?
  spaciousness_1km                                                  Float?
  popularity_score                                                  Float?
  indoor_outdoor                                                    String
  is_landmark                                                       Boolean                  @default(false)
  landmark_class_id                                                 Int?
  address                                                           String?
  province                                                          String?
  location_updated_at                                               DateTime                 @default(now()) @db.Timestamptz(6)
  description_embedding                                             Unsupported("vector(384)")?
  interaction_log                                                   interaction_log[]
  landmark_recognition                                              landmark_recognition[]
  place_crowd_snapshot                                              place_crowd_snapshot[]
  place_image                                                       place_image?
  place_nearby_amenity_place_nearby_amenity_amenity_place_idToplace place_nearby_amenity[]   @relation("place_nearby_amenity_amenity_place_idToplace")
  place_nearby_amenity_place_nearby_amenity_place_idToplace         place_nearby_amenity[]   @relation("place_nearby_amenity_place_idToplace")
  place_opening_hour                                                place_opening_hour[]
  place_peak_time                                                   place_peak_time[]
  place_tag_map                                                     place_tag_map[]
  trip                                                              trip[]
  trip_slot                                                         trip_slot[]

  @@index([geom], map: "idx_place_geom", type: Gist)
  @@index([indoor_outdoor], map: "idx_place_indoor")
  @@index([landmark_class_id], map: "idx_place_landmark", where: raw("(is_landmark = true)"))
  @@index([popularity_score(sort: Desc)], map: "idx_place_popularity")
  @@index([province], map: "idx_place_province")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model place_crowd_snapshot {
  snapshot_id     BigInt   @id @default(autoincrement())
  place_id        BigInt
  recorded_at     DateTime @db.Timestamptz(6)
  emptiness_level Float
  place           place    @relation(fields: [place_id], references: [place_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([place_id, recorded_at(sort: Desc)], map: "idx_crowd_place_time")
}

model place_image {
  image_id      BigInt  @id @default(autoincrement())
  place_id      BigInt  @unique(map: "idx_place_image_primary", where: raw("(is_primary = true)"))
  url           String
  is_primary    Boolean @default(false)
  display_order Int     @default(0)
  place         place   @relation(fields: [place_id], references: [place_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([place_id, display_order], map: "idx_place_image_place")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model place_nearby_amenity {
  place_id                                           BigInt
  amenity_place_id                                   BigInt
  distance_m                                         Float
  place_place_nearby_amenity_amenity_place_idToplace place  @relation("place_nearby_amenity_amenity_place_idToplace", fields: [amenity_place_id], references: [place_id], onDelete: Cascade, onUpdate: NoAction)
  place_place_nearby_amenity_place_idToplace         place  @relation("place_nearby_amenity_place_idToplace", fields: [place_id], references: [place_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([place_id, amenity_place_id])
  @@index([amenity_place_id], map: "idx_nearby_amenity")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model place_opening_hour {
  place_id    BigInt
  day_of_week Int      @db.SmallInt
  open_time   DateTime @db.Time(6)
  close_time  DateTime @db.Time(6)
  place       place    @relation(fields: [place_id], references: [place_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([place_id, day_of_week, open_time])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model place_peak_time {
  place_id        BigInt
  start_time      DateTime @db.Time(6)
  end_time        DateTime @db.Time(6)
  emptiness_level Float
  place           place    @relation(fields: [place_id], references: [place_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([place_id, start_time])
}

model place_tag {
  tag_id        Int             @id
  name          String          @unique @db.VarChar(50)
  display_name  String          @db.VarChar(100)
  place_tag_map place_tag_map[]
}

model place_tag_map {
  place_id  BigInt
  tag_id    Int
  place     place     @relation(fields: [place_id], references: [place_id], onDelete: Cascade, onUpdate: NoAction)
  place_tag place_tag @relation(fields: [tag_id], references: [tag_id], onDelete: NoAction, onUpdate: NoAction)

  @@id([place_id, tag_id])
  @@index([tag_id], map: "idx_tagmap_tag")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model replan_proposal {
  proposal_id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trip_id               String      @db.Uuid
  triggered_by_event_id String?     @db.Uuid
  created_at            DateTime    @default(now()) @db.Timestamptz(6)
  expires_at            DateTime    @db.Timestamptz(6)
  old_plan_snapshot     Json
  new_plan_snapshot     Json
  causal_trace          Json
  score_before          Float
  score_after           Float
  status                String      @default("pending")
  decided_at            DateTime?   @db.Timestamptz(6)
  trip_event            trip_event? @relation(fields: [triggered_by_event_id], references: [event_id], onDelete: NoAction, onUpdate: NoAction)
  trip                  trip        @relation(fields: [trip_id], references: [trip_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([trip_id], map: "idx_proposal_trip_pending", where: raw("(status = 'pending'::text)"))
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model trip {
  trip_id              String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id              String                 @db.Uuid
  title                String?
  destination_city     String
  start_date           DateTime               @db.Date
  end_date             DateTime               @db.Date
  status               String                 @default("draft")
  budget_total         Int
  raw_prompt           String?
  parsed_slots         Json?
  hotel_place_id       BigInt?
  objective_score      Float?
  current_arm_id       Int?
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  deleted_at           DateTime?              @db.Timestamptz(6)
  share_token          String?                @unique
  share_expires_at     DateTime?              @db.Timestamptz(6)
  landmark_recognition landmark_recognition[]
  replan_proposal      replan_proposal[]
  bandit_arm           bandit_arm?            @relation(fields: [current_arm_id], references: [arm_id], onDelete: NoAction, onUpdate: NoAction)
  place                place?                 @relation(fields: [hotel_place_id], references: [place_id], onDelete: NoAction, onUpdate: NoAction)
  app_user             app_user               @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  trip_event           trip_event[]
  trip_slot            trip_slot[]
  trip_state_snapshot  trip_state_snapshot[]
  trip_day_start       trip_day_start[]

  @@index([status], map: "idx_trip_status", where: raw("(status = ANY (ARRAY['active'::text, 'draft'::text]))"))
  @@index([user_id, created_at(sort: Desc)], map: "idx_trip_user")
}

model trip_day_start {
  trip_id    String   @db.Uuid
  day_index  Int
  lat        Float
  lng        Float
  name       String
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  trip       trip     @relation(fields: [trip_id], references: [trip_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([trip_id, day_index])
  @@index([trip_id], map: "idx_trip_day_start_trip")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model trip_event {
  event_id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trip_id           String            @db.Uuid
  event_type        String
  severity          Float
  detected_at       DateTime          @default(now()) @db.Timestamptz(6)
  source            String
  payload           Json
  affected_slot_ids String[]          @default([]) @db.Uuid
  status            String            @default("open")
  replan_proposal   replan_proposal[]
  trip              trip              @relation(fields: [trip_id], references: [trip_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([trip_id, status], map: "idx_event_status", where: raw("(status = 'open'::text)"))
  @@index([trip_id, detected_at(sort: Desc)], map: "idx_event_trip")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model trip_slot {
  slot_id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trip_id             String                @db.Uuid
  day_index           Int
  slot_order          Int
  version             Int                   @default(1)
  place_id            BigInt
  planned_start       DateTime              @db.Timestamptz(6)
  planned_end         DateTime              @db.Timestamptz(6)
  actual_start        DateTime?             @db.Timestamptz(6)
  actual_end          DateTime?             @db.Timestamptz(6)
  estimated_cost      Int                   @default(0)
  activity_type       String
  rationale           String?
  status              String                @default("planned")
  is_locked           Boolean               @default(false)
  place               place                 @relation(fields: [place_id], references: [place_id], onDelete: NoAction, onUpdate: NoAction)
  trip                trip                  @relation(fields: [trip_id], references: [trip_id], onDelete: Cascade, onUpdate: NoAction)
  trip_state_snapshot trip_state_snapshot[]

  @@unique([trip_id, day_index, slot_order, version])
  @@index([trip_id, day_index, slot_order], map: "idx_slot_trip_active", where: raw("(status = 'planned'::text)"))
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model trip_state_snapshot {
  snapshot_id        String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trip_id            String                    @db.Uuid
  slot_id            String?                   @db.Uuid
  captured_at        DateTime                  @default(now()) @db.Timestamptz(6)
  day_index          Int
  slot_order         Int
  time_remaining_min Int
  budget_remaining   Int
  fatigue            Float
  current_geom       Unsupported("geography")?
  mood_proxy         Float
  source             String
  trip_slot          trip_slot?                @relation(fields: [slot_id], references: [slot_id], onUpdate: NoAction)
  trip               trip                      @relation(fields: [trip_id], references: [trip_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([trip_id, captured_at(sort: Desc)], map: "idx_state_trip")
}

model user_arm_stat {
  user_id      String     @db.Uuid
  arm_id       Int
  pulls        Int        @default(0)
  total_reward Float      @default(0)
  updated_at   DateTime   @default(now()) @db.Timestamptz(6)
  bandit_arm   bandit_arm @relation(fields: [arm_id], references: [arm_id], onDelete: NoAction, onUpdate: NoAction)
  app_user     app_user   @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, arm_id])
}

model user_objective_weights {
  user_id           String     @id @db.Uuid
  w_interest        Float
  w_pace            Float
  w_distance        Float
  w_budget          Float
  w_weather         Float
  w_risk            Float
  w_stability       Float      @default(0.5)
  w_potential_bias  Float      @default(1.0)
  w_proximity       Float      @default(0.0)
  w_synergy         Float      @default(0.3)
  current_arm_id    Int
  soft_constraints  Json       @default("[]")
  updated_at        DateTime   @default(now()) @db.Timestamptz(6)
  bandit_arm        bandit_arm @relation(fields: [current_arm_id], references: [arm_id], onDelete: NoAction, onUpdate: NoAction)
  app_user          app_user   @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model user_preference {
  user_id               String   @id @db.Uuid
  primary_purpose       String
  preferred_tag_ids     Int[]
  pace                  Float
  daily_schedule_type   String
  food_preferences      String[] @default([])
  budget_per_day_min    Int
  budget_per_day_max    Int
  group_type            String
  mobility_restrictions String[] @default([])
  preference_vector     Float[]
  updated_at            DateTime @default(now()) @db.Timestamptz(6)
  app_user              app_user @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model user_similarity {
  user_id                                            String   @db.Uuid
  similar_user_id                                    String   @db.Uuid
  similarity                                         Float
  rank_position                                      Int
  computed_at                                        DateTime @default(now()) @db.Timestamptz(6)
  app_user_user_similarity_similar_user_idToapp_user app_user @relation("user_similarity_similar_user_idToapp_user", fields: [similar_user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  app_user_user_similarity_user_idToapp_user         app_user @relation("user_similarity_user_idToapp_user", fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, similar_user_id])
  @@index([user_id, rank_position], map: "idx_usersim_rank")
}
