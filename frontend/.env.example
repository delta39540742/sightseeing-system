# API URLs — chỉ cần set khi deploy production (frontend và backend khác domain).
# Để trống khi dev local (Vite proxy sẽ tự handle /api và /pref/api).
VITE_API_BASE_URL=https://<YOUR_BACKEND_SERVICE>.onrender.com/api
VITE_PREF_API_BASE_URL=https://<YOUR_PREF_SERVICE>.onrender.com/api

# Firebase Web Client (Vite — tất cả biến phải có prefix VITE_)
# Lấy từ Firebase Console → Project Settings → Your apps → Web app → SDK setup
VITE_FIREBASE_API_KEY=<YOUR_API_KEY>
VITE_FIREBASE_AUTH_DOMAIN=<YOUR_PROJECT_ID>.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=<YOUR_PROJECT_ID>
VITE_FIREBASE_STORAGE_BUCKET=<YOUR_PROJECT_ID>.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=<YOUR_MESSAGING_SENDER_ID>
VITE_FIREBASE_APP_ID=<YOUR_APP_ID>
